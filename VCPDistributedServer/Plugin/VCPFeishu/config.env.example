# VCPFeishu 插件环境配置示例 — 复制为 config.env 并填写实际值
# 也可使用「扫码注册」功能自动创建应用并生成配置

# ============================================
# 飞书自建应用（二选一：手动填写 或 使用扫码注册）
# ============================================
# 从飞书开放平台开发者后台获取
# FeishuAppId=cli_xxxxxxxxxxxx
# FeishuAppSecret=xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 绑定的 Agent（必填）
# 必须是 AgentAssistant config.json 里某个 agent 的 chineseName
# ============================================
FeishuBindAgent=nova

# ============================================
# WebSocket 长连接（可选，带默认值）
# ============================================
# 最大重连次数，-1 = 无限重连（生产常驻推荐）
FeishuMaxReconnect=-1

# ============================================
# 回复策略（可选）
# ============================================
# 是否启用两段式流式回复（先发提示再发全文）
FeishuStreamReply=true
# 流式中间提示语
FeishuStreamHint=正在思考中…
# agent 推理超时毫秒
FeishuAgentTimeoutMs=358000

# ============================================
# 会话与工具（可选）
# ============================================
# 传给 AgentAssistant 的 session_id 前缀
FeishuSessionPrefix=feishu
# 唤醒 agent 时临时注入的工具组，逗号分隔
FeishuInjectTools=VCPFeishu

# ============================================
# 白名单（可选）
# 留空 = 不限制；填 open_id 逗号分隔 = 仅这些用户可触发
# ============================================
# FeishuAllowedUsers=ou_xxxxx,ou_yyyyy

# ============================================
# 调试
# ============================================
DebugMode=false
